@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="page-section">
    <div class="public-card error-card">
        <span class="eyebrow">Error @Model.StatusCode</span>
        <h1>@Model.Title</h1>
        <p>@Model.Message</p>
        <div class="cta-row">
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Go to Home</a>
            <a class="btn btn-outline-primary" href="javascript:history.back()">Go Back</a>
        </div>

        @if (Model.ShowRequestId)
        {
            <p class="small text-muted mt-3 mb-0">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }
    </div>
</section>
