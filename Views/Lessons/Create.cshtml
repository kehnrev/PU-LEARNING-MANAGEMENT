@model Lesson
@{
    ViewData["Title"] = "Add Lecture / Lesson";
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">Learning materials</span>
        <h1>Add Lecture / Lesson</h1>
    </div>
    <a class="btn btn-outline-primary" asp-action="Index" asp-route-courseId="@Model.CourseId">Back</a>
</div>

<section class="panel form-panel">
    <form asp-action="Create" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_LessonForm" model="Model" />
        <div class="button-row mt-4">
            <button class="btn btn-primary" type="submit">Save Lecture / Lesson</button>
            <a class="btn btn-outline-primary" asp-action="Index" asp-route-courseId="@Model.CourseId">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
