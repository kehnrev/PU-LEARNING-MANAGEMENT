@model Lesson
@{
    ViewData["Title"] = Model.Title;
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">@Model.Course?.Title</span>
        <h1>@Model.Title</h1>
    </div>
    <div class="button-row">
        <a class="btn btn-outline-primary" asp-action="Index" asp-route-courseId="@Model.CourseId">Back</a>
        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.LessonId">Edit Lecture / Lesson</a>
        }
    </div>
</div>

<section class="panel lesson-reader" data-lesson-id="@Model.LessonId" data-lesson-title="@Model.Title" data-course-title="@Model.Course?.Title">
    <div class="lesson-meta">
        <span class="badge @(Model.IsAvailableOffline ? "text-bg-success" : "text-bg-secondary")">@(Model.IsAvailableOffline ? "Available offline" : "Online only")</span>
        <span>@Model.DateCreated.ToLocalTime().ToString("MMM dd, yyyy")</span>
    </div>
    <p class="lesson-content" id="lessonContent">@Model.Content</p>
    @if (!string.IsNullOrWhiteSpace(Model.FilePath))
    {
        <p><strong>File:</strong> @Model.FilePath</p>
    }
    @if (Model.IsAvailableOffline)
    {
        <button class="btn btn-outline-primary" id="saveLessonOffline" type="button">Save Offline</button>
    }
</section>
