@model UserFormViewModel
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Edit User" : "Create User";
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">User management</span>
        <h1>@ViewData["Title"]</h1>
    </div>
    <a class="btn btn-outline-primary" asp-action="Users">Back to Users</a>
</div>

<section class="panel form-panel">
    <form asp-action="@(isEdit ? "EditUser" : "CreateUser")" method="post" novalidate>
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Role" class="form-label"></label>
                <select asp-for="Role" class="form-select" asp-items="Html.GetEnumSelectList<UserRole>()"></select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Password" class="form-label"></label>
                <div class="password-field">
                    <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="@(isEdit ? "Leave blank to keep current password" : "Set password")" />
                    <button class="password-toggle" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">
                        <span class="password-toggle-label visually-hidden">Show password</span>
                        <svg class="password-icon password-icon-eye" aria-hidden="true" viewBox="0 0 24 24">
                            <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="password-icon password-icon-eye-off" aria-hidden="true" viewBox="0 0 24 24">
                            <path d="M3 3l18 18" />
                            <path d="M10.7 5.2A10.7 10.7 0 0 1 12 5c6 0 9.5 7 9.5 7a16.2 16.2 0 0 1-3 4.1" />
                            <path d="M6.5 6.8C3.9 8.6 2.5 12 2.5 12S6 19 12 19c1.5 0 2.9-.4 4.1-1" />
                            <path d="M9.9 9.9A3 3 0 0 0 14.1 14.1" />
                        </svg>
                    </button>
                </div>
                <div class="form-text">
                    @if (isEdit)
                    {
                        <span>Leave blank to keep current password. For security, existing passwords cannot be viewed.</span>
                    }
                    else
                    {
                        <span>Set the first password for this user.</span>
                    }
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                    <div class="form-text"
                         data-checkbox-feedback
                         data-checked-message="This user can login and access the system."
                         data-unchecked-message="This user is disabled and cannot login.">
                        @(Model.IsActive
                            ? "This user can login and access the system."
                            : "This user is disabled and cannot login.")
                    </div>
                </div>
            </div>
        </div>
        <button class="btn btn-primary mt-4" type="submit">Save User</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
